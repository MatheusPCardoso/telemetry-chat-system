DATABASE_URL="mongodb://chatbot:chatbot123@localhost:27017/chatbot?authSource=admin&replicaSet=rs0&directConnection=true"
REDIS_HOST="localhost"
REDIS_PORT=6379
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="your-refresh-secret-key-here"
