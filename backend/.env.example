PORT=3000
CORS_ORIGIN="http://localhost:5173"
# Local development defaults:
# - MongoDB published by Docker Compose on localhost:27017
# - Redis published by Docker Compose on localhost:6379
# Docker Compose overrides the hostnames for the backend container.

